{
  "name": "my-portfolio-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "description": "Enterprise Monorepo for My Portfolio",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspace=apps/frontend",
    "dev:frontend": "npm run dev --workspace=@my-portfolio/frontend",
    "dev:backend": "npm run dev --workspace=@my-portfolio/backend",
    "clean": "npm run clean --workspaces",
    "test": "npm run test --workspaces --if-present",
    "seed-projects": "node database/seeders/seed-projects.js",
    "seed-admin": "node database/seeders/seed-admin.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.9.6",
    "typescript": "~5.8.2"
  }
}
